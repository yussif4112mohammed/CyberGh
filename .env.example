# ── Database (Aiven MySQL) ─────────────────────────────────────
# Use your existing Aiven DB or create a new one for this project
DB_HOST=your-mysql-host.aivencloud.com
DB_PORT=15038
DB_USER=avnadmin
DB_PASSWORD=your-aiven-password
DB_NAME=cybergh
DB_SSL=true

# ── HaveIBeenPwned API (optional — breach check module) ────────
# Get a free key at https://haveibeenpwned.com/API/Key
# Without this, breach checks will show "not available" gracefully
HIBP_API_KEY=

# ── Email (Resend) — add in Week 2 ────────────────────────────
# Get a free key at https://resend.com — 3,000 emails/month free
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
