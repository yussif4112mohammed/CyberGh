# ── Database (Aiven PostgreSQL) ────────────────────────────────
# Copy the full "Service URI" from your Aiven PostgreSQL overview page
# It looks like: postgres://avnadmin:PASSWORD@pg-xxx.aivencloud.com:PORT/defaultdb?sslmode=require
DATABASE_URL=postgres://avnadmin:PASSWORD@pg-271e7687-cybergh.k.aivencloud.com:17595/defaultdb?sslmode=require

# ── HaveIBeenPwned API (optional — breach check module) ────────
# Get a free key at https://haveibeenpwned.com/API/Key
# Without this, breach checks will show "not available" gracefully
HIBP_API_KEY=

# ── Email (Resend) — add in Week 2 ────────────────────────────
# Get a free key at https://resend.com — 3,000 emails/month free
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
